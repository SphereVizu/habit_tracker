<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/newhabit_navigation"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.anmp_32bit.habittracker.view.DashboardFragment"
        android:label="Dashboard Screen"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/actionLoginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_newHabitFragment"
            app:destination="@id/newHabitFragment" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.anmp_32bit.habittracker.view.LoginFragment"
        android:label="Login Screen"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/newHabitFragment"
        android:name="com.anmp_32bit.habittracker.view.NewHabitFragment"
        android:label="Create New Habit"
        tools:layout="@layout/fragment_new_habit" />
</navigation>